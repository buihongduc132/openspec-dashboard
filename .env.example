# Copy to .env.local and fill in. NEVER commit the real .env.local.
# Local dev default (matches the original template):
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/app_db

# Optional. Base used to resolve absolute filesystem paths in copied entity
# references (design decision D2). When unset/blank, each project's `rootPath`
# is used as the base. Set this when the agent's filesystem view differs from
# the dashboard host (e.g. agent runs in a container) so the absolute paths in
# the copied reference point at the right place.
# REFERENCE_REPO_ROOT=/path/to/repos
